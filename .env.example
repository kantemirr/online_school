# ── Скопируйте в .env и при необходимости поменяйте значения ──

# Окружение
PROJECT_NAME=CodeKids — онлайн-школа программирования
ENVIRONMENT=local
DEBUG=true

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=codekids

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# JWT
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7

# Загрузка проектов (Этап 5c — локальный том)
UPLOADS_DIR=/data/uploads

# Песочница (Этап 5b)
SANDBOX_IMAGE=codekids-sandbox:latest
SANDBOX_MEM_LIMIT=128m
SANDBOX_CPU_LIMIT=0.5
SANDBOX_PIDS_LIMIT=64
SANDBOX_TIMEOUT_SEC=8

# Email (SMTP → MailHog)
SMTP_HOST=mailhog
SMTP_PORT=1025
EMAIL_FROM=no-reply@codekids.local
# Базовый URL фронтенда для ссылок в письмах (через nginx)
FRONTEND_BASE_URL=http://localhost:8080

# Bootstrap-администратор (создаётся командой python -m app.modules.auth.bootstrap)
# Домен не .local/.example/.test (их отвергает email-валидатор)
BOOTSTRAP_ADMIN_EMAIL=admin@codekids.ru
BOOTSTRAP_ADMIN_PASSWORD=admin12345

# CORS (через запятую)
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
