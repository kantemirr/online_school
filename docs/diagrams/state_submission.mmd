%% Рис. 12 — UML Statechart «Жизненный цикл работы (Submission)».
%% Универсален для трёх механик: квиз / код / проект. Рендер: https://mermaid.live
stateDiagram-v2
    [*] --> Создана : отправка работы

    state "Тип задания" as Тип <<choice>>
    Создана --> Тип

    %% Квиз — мгновенная автопроверка
    Тип --> Проверена : квиз (автооценка)

    %% Код — асинхронно через песочницу
    Тип --> ВОчереди : код
    ВОчереди --> Выполняется : взято воркером
    Выполняется --> Проверена : тесты прогнаны

    %% Проект — ручная проверка
    Тип --> НаПроверке : проект
    НаПроверке --> Принята : преподаватель принял
    НаПроверке --> НаДоработке : отправлено на доработку
    НаДоработке --> ВОчереди : повторная отправка

    state Проверена {
        [*] --> passed
        [*] --> partial
        [*] --> failed
    }

    Проверена --> [*] : passed → урок закрыт
    Принята --> [*] : урок закрыт

    note right of ВОчереди
        Деградация: если Docker недоступен —
        result_json.unavailable, урок не закрывается
    end note
